# Environment Variables for CosmicSec Platform
# Copy this file to .env and update with your values

# Database Configuration
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=cosmicsec
POSTGRES_USER=cosmicsec

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password

# MongoDB Configuration
MONGO_PASSWORD=your_secure_mongo_password

# RabbitMQ Configuration
RABBITMQ_PASSWORD=your_secure_rabbitmq_password

# JWT Configuration
JWT_SECRET_KEY=your_secure_jwt_secret_key_min_32_characters

# API Keys (optional)
OPENAI_API_KEY=sk-your-openai-api-key
OLLAMA_BASE_URL=                    # Local LLM (e.g. http://localhost:11434)
OLLAMA_MODEL=llama3                  # Ollama model name
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
DISCORD_BOT_TOKEN=your-discord-bot-token

# Environment
ENVIRONMENT=development
DEBUG=true

# Service URLs (for production)
API_GATEWAY_URL=http://localhost:8000
AUTH_SERVICE_URL=http://localhost:8001
SCAN_SERVICE_URL=http://localhost:8002

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
COSMICSEC_CORS_ORIGINS=http://localhost:3000,http://localhost:4173

# Logging
LOG_LEVEL=INFO
