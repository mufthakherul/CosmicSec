# Environment Variables for CosmicSec Platform
# Copy this file to .env and update with your values

# Deployment Mode (auto-detected if not specified)
# Options: local_dev, docker, docker_compose, kubernetes, self_hosted
# COSMICSEC_DEPLOYMENT_MODE=local_dev

# Service Discovery Configuration
# In local dev: automatically uses localhost:PORT
# In Docker: automatically uses service-name:PORT
# In self-hosted: configure SERVICE_HOST to specify your server IP/domain
# SERVICE_HOST=localhost
# SERVICE_PROTOCOL=http

# Database Configuration
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=cosmicsec
POSTGRES_USER=cosmicsec

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password

# MongoDB Configuration
MONGO_PASSWORD=your_secure_mongo_password

# RabbitMQ Configuration
RABBITMQ_PASSWORD=your_secure_rabbitmq_password

# JWT Configuration
JWT_SECRET_KEY=your_secure_jwt_secret_key_min_32_characters

# 2FA Encryption Key (Fernet-compatible base64 key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
COSMICSEC_2FA_KEY=

# API Keys (optional)
OPENAI_API_KEY=sk-your-openai-api-key
OLLAMA_BASE_URL=                    # Local LLM (e.g. http://localhost:11434)
OLLAMA_MODEL=llama3                  # Ollama model name
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
DISCORD_BOT_TOKEN=your-discord-bot-token

# Environment
ENVIRONMENT=development
DEBUG=true

# Service URLs (optional overrides for custom routing)
# These are OPTIONAL - service discovery handles them automatically!
# Override only if you need custom routing or non-standard deployment

# API Gateway (default: auto-discovered)
# API_GATEWAY_SERVICE_URL=http://api-gateway:8000

# Core Services
# AUTH_SERVICE_URL=http://auth-service:8001
# SCAN_SERVICE_URL=http://scan-service:8002
# AI_SERVICE_URL=http://ai-service:8003
# RECON_SERVICE_URL=http://recon-service:8004
# REPORT_SERVICE_URL=http://report-service:8005
# COLLAB_SERVICE_URL=http://collab-service:8006

# Plugin and Integration Services
# PLUGINS_SERVICE_URL=http://plugin-registry:8007
# INTEGRATION_SERVICE_URL=http://integration-service:8008

# Specialized Services
# BUGBOUNTY_SERVICE_URL=http://bugbounty-service:8009
# PHASE5_SERVICE_URL=http://phase5-service:8010
# AGENT_RELAY_SERVICE_URL=http://agent-relay:8011
# NOTIFICATION_SERVICE_URL=http://notification-service:8012
# COMPLIANCE_SERVICE_URL=http://compliance-service:8013
# ORG_SERVICE_URL=http://org-service:8014
# ADMIN_SERVICE_URL=http://admin-service:8015

# Alternative: Use global SERVICE_HOST for all services (e.g., when using external load balancer)
# SERVICE_HOST=api.example.com
# SERVICE_PROTOCOL=https

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
COSMICSEC_CORS_ORIGINS=http://localhost:3000,http://localhost:4173

# Logging
LOG_LEVEL=INFO
