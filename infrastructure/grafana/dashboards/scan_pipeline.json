{
  "annotations": { "list": [] },
  "description": "CosmicSec — Scan Pipeline Monitoring",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "cosmicsec_scan_queue_depth", "legendFormat": "Queue Depth" }
      ],
      "title": "Scan Queue Depth",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(cosmicsec_scan_active)", "legendFormat": "Active Scans" }
      ],
      "title": "Active Scans",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 3,
      "targets": [
        {
          "expr": "rate(cosmicsec_scans_completed_total[5m])",
          "legendFormat": "Completed/s"
        },
        {
          "expr": "rate(cosmicsec_scans_failed_total[5m])",
          "legendFormat": "Failed/s"
        }
      ],
      "title": "Scan Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (severity) (rate(cosmicsec_findings_total[5m]))",
          "legendFormat": "{{ severity }}"
        }
      ],
      "title": "Findings by Severity",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cosmicsec", "scans"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "CosmicSec — Scan Pipeline",
  "uid": "cosmicsec-scan-pipeline",
  "version": 1
}
